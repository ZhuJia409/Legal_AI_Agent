# Application
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# OpenAI-compatible model gateway
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen3.6-flash
LLM_FALLBACK_MODEL=qwen-plus
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=legal_ai_agent
MYSQL_USER=legal_agent
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017/legal_ai_agent

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=legal-ai-agent
