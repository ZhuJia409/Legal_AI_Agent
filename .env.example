# Application
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# OpenAI-compatible model gateway
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen3.7-plus
LLM_FALLBACK_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=legal-ai-agent-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=legal_ai_agent
MYSQL_USER=legal_agent
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017/legal_ai_agent

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=legal-ai-agent

# MinerU precise document parsing API
# Docs: https://mineru.net/apiManage/docs
MINERU_API_KEY=
MINERU_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL_SECONDS=2
MINERU_POLL_TIMEOUT_SECONDS=180

# Offline PDF renderer (run scripts/setup-tectonic.ps1 first)
TECTONIC_PATH=.tools/tectonic/tectonic.exe
TECTONIC_TIMEOUT_SECONDS=90
