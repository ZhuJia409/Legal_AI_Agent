\documentclass[UTF8,a4paper,11pt,fontset=fandol]{ctexart}

\usepackage[a4paper,margin=2.3cm,headheight=16pt,footskip=1.2cm]{geometry}
\usepackage{array}
\usepackage{enumitem}
\usepackage{fancyhdr}
\usepackage{longtable}
\usepackage[table]{xcolor}

\definecolor{LegalGreen}{HTML}{174C3C}
\definecolor{LegalGreenLight}{HTML}{E8F1ED}
\definecolor{WarningRed}{HTML}{A61B1B}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.45em}
\setlist[itemize]{leftmargin=1.6em,itemsep=0.18em,topsep=0.2em}
\renewcommand{\arraystretch}{1.3}

\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\color{LegalGreen}\small 合同审查报告}
\fancyhead[R]{\color{LegalGreen}\small << status_label|latex_escape >>}
<% if status == "partial" %>
\fancyfoot[C]{\color{WarningRed}\bfseries 不完整报告——不可作为签署依据\quad 第\thepage 页}
<% else %>
\fancyfoot[C]{\color{LegalGreen}\small 第\thepage 页}
<% endif %>
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}

\newcommand{\reportsection}[1]{%
  \vspace{0.5em}%
  {\Large\bfseries\color{LegalGreen} #1}\par%
  \vspace{0.15em}\color{LegalGreen}\hrule\color{black}\vspace{0.4em}%
}
\newcommand{\reportsubsection}[1]{%
  \vspace{0.3em}{\large\bfseries\color{LegalGreen} #1}\par\vspace{0.1em}%
}
\newcommand{\fieldlabel}[1]{\textbf{\color{LegalGreen}#1}}

\begin{document}

{\LARGE\bfseries\color{LegalGreen} 合同审查报告}\hfill
{\small << status_label|latex_escape >>}\par
{\large << title|latex_escape >>}\par
<% if status == "partial" %>
\fcolorbox{WarningRed}{white}{%
  \parbox{0.94\textwidth}{\bfseries\color{WarningRed}<< partial_warning|latex_escape >>}%
}
<% endif %>

\reportsection{一、合同基本信息}
\begin{longtable}{>{\bfseries\color{LegalGreen}}p{3.8cm}p{10.2cm}}
  合同名称 & << title|latex_escape >> \\
  来源文件 & << source_filename|latex_escape_breakable_filename >> \\
  合同编号 & << contract_number|latex_escape >> \\
  合同类型 & << contract_type_label|latex_escape >> \\
  签约双方 & << contract_parties|latex_escape >> \\
  金额与期限 & << amount_and_term|latex_escape >> \\
  审查日期 & << generated_at|latex_escape >> \\
  审查立场 & << review_perspective_label|latex_escape >> \\
  审查人 & << reviewer|latex_escape >> \\
\end{longtable}

\reportsection{二、审查范围与依据}
\fieldlabel{合同版本或来源：}<< source_filename|latex_escape_breakable_filename >>\par
\fieldlabel{已完成审查模块：}
<% if completed_modules %>
<< completed_modules|join('、')|latex_escape >>
<% else %>
未从材料确认。
<% endif %>

\reportsubsection{主要依据}
<% if review_bases %>
\begin{itemize}
<% for basis in review_bases %>
  \item << basis|latex_escape >>
<% endfor %>
\end{itemize}
<% else %>
未从材料确认。
<% endif %>
{\small\color{WarningRed}未接入权威法条及行业惯例核验，相关依据须由专业律师复核。}
<% if scope_warning %>
\par{\small\color{WarningRed}<< scope_warning|latex_escape >>}
<% endif %>

\reportsection{三、重点风险及修改建议}
\begin{tabular}{>{\bfseries\color{LegalGreen}}p{3.1cm}p{1.2cm} >{\bfseries\color{LegalGreen}}p{3.1cm}p{1.2cm}}
  致命风险 & << risk_counts.fatal >> & 高风险 & << risk_counts.high >> \\
  中风险 & << risk_counts.medium >> & 低风险 & << risk_counts.low >> \\
\end{tabular}

<% if findings %>
<% for finding in findings %>
\reportsubsection{<< loop.index >>. << finding.issue|latex_escape >>}
\fieldlabel{风险等级：}<< finding.risk_label|latex_escape >>\quad
\fieldlabel{合同位置：}<< finding.contract_location|latex_escape >>\par
\fieldlabel{风险描述：}<< finding.issue|latex_escape >>\par
\fieldlabel{法律后果：}<< finding.impact|latex_escape >>\par
\fieldlabel{修改建议：}<< finding.suggestion|latex_escape >>\par
\fieldlabel{谈判策略：}<< finding.negotiation_strategy|latex_escape >>
<% endfor %>
<% else %>
未从材料确认具体风险事项。
<% endif %>
<% if omitted_findings_count %>
\par{\small 另有 << omitted_findings_count >> 项风险未展开，已计入风险统计。}
<% endif %>

\reportsection{四、综合审查结论}
\fieldlabel{总体风险等级：}<< overall_risk_label|latex_escape >>\par
\fieldlabel{是否建议签署：}<< signing_recommendation_label|latex_escape >>\par
\fieldlabel{结论摘要：}<< executive_summary|latex_escape >>

\reportsubsection{签署前提}
<% if preconditions %>
\begin{itemize}
<% for precondition in preconditions %>
  \item << precondition|latex_escape >>
<% endfor %>
\end{itemize}
<% else %>
未从材料确认；签署前仍应由专业律师复核。
<% endif %>

\reportsection{五、附件状态}
\begin{longtable}{>{\bfseries\color{LegalGreen}}p{4.5cm}p{9.5cm}}
<% for attachment in attachments %>
  << attachment.name|latex_escape >> & << attachment.status|latex_escape >> \\
<% endfor %>
\end{longtable}

\vspace{0.6em}
{\small\color{LegalGreen}本报告由人工智能辅助生成，仅供审查参考，不构成确定法律结论；所有结论与建议必须由专业法律人士复核，并结合完整材料判断。}
<% if status == "partial" %>
\par\fcolorbox{WarningRed}{white}{%
  \parbox{0.94\textwidth}{\bfseries\color{WarningRed}<< partial_warning|latex_escape >>}%
}
<% endif %>

\end{document}
